#!/bin/bash

BRANCH="${POULPE_BRANCH:-main}"
CURRENT=$(git branch --show-current)

if [ "$CURRENT" = "$BRANCH" ]; then
  echo "Error: you are already on '$BRANCH'. Switch to a feature branch first."
  exit 1
fi

git fetch origin "$BRANCH":"$BRANCH" && git rebase "$BRANCH" --autostash || exit 1

commits_ahead=$(git rev-list --count "$BRANCH"..HEAD 2>/dev/null)
if [ "$commits_ahead" -gt 1 ] 2>/dev/null; then
  echo "=================================================="
  echo "  WARNING: $commits_ahead commits ahead of $BRANCH!"
  echo "  You may want to squash before force pushing."
  echo "=================================================="
  echo ""
  git log --oneline "$BRANCH"..HEAD
  echo ""
  read -p "Continue with force push? [y/N] " answer
  [[ "$answer" =~ ^[Yy]$ ]] || exit 1
fi

git push -f

commits_ahead=$(git rev-list --count "$BRANCH"..HEAD 2>/dev/null)
if [ "$commits_ahead" -eq 1 ] 2>/dev/null; then
  echo ""
  echo "1 commit ahead of $BRANCH:"
  git log --oneline -1 HEAD
elif [ "$commits_ahead" -gt 1 ] 2>/dev/null; then
  echo ""
  echo "$commits_ahead commits ahead of $BRANCH:"
  git log --oneline "$BRANCH"..HEAD
fi
